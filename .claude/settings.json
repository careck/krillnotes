{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cargo test *)",
      "Bash(cargo test)",
      "Bash(cargo build *)",
      "Bash(cargo build)",
      "Bash(cargo check *)",
      "Bash(cargo check)",
      "Bash(cargo clippy *)",
      "Bash(cargo doc *)",
      "Bash(cargo fmt *)",
      "Bash(npm run *)",
      "Bash(npx tsc *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed -n *)",
      "Bash(wc *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(git -C *)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh repo view *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh workflow view *)",
      "Bash(gh workflow list *)",
      "Read",
      "Write",
      "Edit",
      "MultiEdit"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(cargo publish *)",
      "Bash(gh repo delete *)",
      "Bash(gh pr close *)",
      "Bash(gh issue create *)",
      "Read(.env*)"
    ]
  }
}