{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Krillnotes",
  "version": "0.2.5",
  "identifier": "com.careck.krillnotes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Krillnotes",
        "width": 800,
        "height": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["krillnotes"],
        "name": "Krillnotes Archive",
        "description": "Krillnotes Workspace Archive",
        "mimeType": "application/x-krillnotes",
        "role": "Editor"
      },
      {
        "ext": ["swarm"],
        "name": "Krillnotes Sync Bundle",
        "description": "Krillnotes Peer Sync Bundle",
        "mimeType": "application/x-krillnotes-swarm",
        "role": "Editor"
      }
    ]
  }
}
