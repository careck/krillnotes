<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Declare a proper UTI for .krillnotes archives.
    Without UTExportedTypeDeclarations + LSItemContentTypes, macOS uses the
    legacy kAEOpenDocuments Apple Event path, which calls
    _sendFinishLaunchingNotification from within the event handler and causes
    tao's applicationDidFinishLaunching observer to panic.

    With LSItemContentTypes referencing a declared UTI, macOS routes file opens
    through applicationOpenURLs: (the modern URL delegate) instead, which tao
    surfaces as RunEvent::Opened { urls } without the crash.
  -->
  <key>UTExportedTypeDeclarations</key>
  <array>
    <dict>
      <key>UTTypeIdentifier</key>
      <string>com.careck.krillnotes-archive</string>
      <key>UTTypeDescription</key>
      <string>Krillnotes Archive</string>
      <key>UTTypeConformsTo</key>
      <array>
        <string>public.archive</string>
        <string>public.data</string>
      </array>
      <key>UTTypeTagSpecification</key>
      <dict>
        <key>public.filename-extension</key>
        <array>
          <string>krillnotes</string>
        </array>
        <key>public.mime-type</key>
        <string>application/x-krillnotes</string>
      </dict>
    </dict>
  </array>

  <!--
    Override the CFBundleDocumentTypes generated by Tauri's fileAssociations
    to add LSItemContentTypes, which is what switches macOS from the legacy
    Apple Event path to the modern applicationOpenURLs: path.
  -->
  <key>CFBundleDocumentTypes</key>
  <array>
    <dict>
      <key>CFBundleTypeExtensions</key>
      <array>
        <string>krillnotes</string>
      </array>
      <key>CFBundleTypeName</key>
      <string>Krillnotes Archive</string>
      <key>CFBundleTypeRole</key>
      <string>Editor</string>
      <key>LSHandlerRank</key>
      <string>Owner</string>
      <key>LSItemContentTypes</key>
      <array>
        <string>com.careck.krillnotes-archive</string>
      </array>
    </dict>
  </array>
</dict>
</plist>
